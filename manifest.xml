<?xml version="1.0" encoding="UTF-8"?>
<!--
  Outlook add-in manifest (Microsoft "add-in only" XML format).

  This add-in adds a pinnable task pane to the message-read surface of
  classic Outlook. All resource URLs MUST be HTTPS (a Microsoft requirement).
  The default host below (https://localhost:3000) is for local development;
  replace every occurrence with your HTTPS hosting URL to deploy.

  Validate with: npm run validate
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- A stable GUID identifies this add-in. Generate your own if you fork. -->
  <Id>9ee94300-aff0-4300-b6a7-51ebcea1fbd7</Id>
  <Version>0.1.0</Version>
  <ProviderName>Pixelschmied</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Email Notes" />
  <Description DefaultValue="A private notepad docked next to each mail. Every mail is linked to its own note by a stable, sequential ID. Paste screenshots and attach files. Notes never leave your device." />
  <IconUrl DefaultValue="https://localhost:3000/assets/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/assets/icon-128.png" />
  <SupportUrl DefaultValue="https://github.com/Pixelschmied/Outlook-Notes" />

  <!-- Domains the task pane is allowed to navigate to. -->
  <AppDomains>
    <AppDomain>https://localhost:3000</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <!-- 1.5 enables add-in commands + task-pane pinning. -->
      <Set Name="Mailbox" MinVersion="1.5" />
    </Sets>
  </Requirements>

  <!-- Fallback UI for older clients without add-in-command support. -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://localhost:3000/taskpane.html" />
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <!-- Loaded by ribbon actions that run without opening the pane. -->
          <FunctionFile resid="functionFile" />

          <!-- Message-read surface: a ribbon button that opens the pinnable pane. -->
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="notesGroup">
                <Label resid="groupLabel" />
                <Control xsi:type="Button" id="openNotesButton">
                  <Label resid="openNotesLabel" />
                  <Supertip>
                    <Title resid="openNotesTitle" />
                    <Description resid="openNotesTip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16" />
                    <bt:Image size="32" resid="icon32" />
                    <bt:Image size="80" resid="icon80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl" />
                    <SupportsPinning>true</SupportsPinning>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://localhost:3000/assets/icon-16.png" />
        <bt:Image id="icon32" DefaultValue="https://localhost:3000/assets/icon-32.png" />
        <bt:Image id="icon80" DefaultValue="https://localhost:3000/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="functionFile" DefaultValue="https://localhost:3000/commands.html" />
        <bt:Url id="taskpaneUrl" DefaultValue="https://localhost:3000/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel" DefaultValue="Email Notes" />
        <bt:String id="openNotesLabel" DefaultValue="Notes" />
        <bt:String id="openNotesTitle" DefaultValue="Email Notes" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="openNotesTip" DefaultValue="Open the notepad for the selected mail. Pin it to keep it open while you browse your inbox." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
